# Закон проекта: личный текст владельца — только локально, не в Git.
# Содержимое private/* (кроме .gitkeep) никогда не коммитить.
private/*
!private/.gitkeep

# Frontend (web/)
web/node_modules
web/dist
web/.vite
web/.env
web/.env.*
!web/.env.example

# Утилиты извлечения PDF (локально, не в Git)
.venv-pdf/

# Снимок git Hermes на VPS (генерируется scripts/sync/pull-hermes-from-vps.sh)
docs/sync/hermes-vps-snapshot.txt
